# Server
SERVER_HOST=localhost
SERVER_PORT=8080
SERVER_ENV=development   # development | production

# Database
DATABASE_URL=postgres://user:password@localhost:5432/quiz_db?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MIN=5

# JWT
JWT_SECRET=your-secret-key-here   # Required in production
JWT_ACCESS_EXPIRY_MIN=15
JWT_REFRESH_EXPIRY_DAYS=7

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Super Admin (Basic Auth for /sa/* routes)
SA_ADMIN_LOGIN=admin
SA_ADMIN_PASSWORD=admin
